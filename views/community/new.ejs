<% layout("/layouts/boilerplate") %>

<div class="create-post-page">

    <div class="create-post-card">

        <h2 class="mb-3">
            🌍 Share a Wander Moment
        </h2>

        <p class="text-muted mb-4">
            Share your special travel memories, hidden places, sunsets, food moments, and unforgettable adventures ✨
        </p>

        <form 
            action="/community" 
            method="POST" 
            enctype="multipart/form-data"
            class="post-form"
        >

            <!-- CAPTION -->

            <label class="form-label">
                Write Your Moment
            </label>

            <textarea 
                name="community[caption]" 
                placeholder="Describe your travel memory..."
                required
                class="form-control mb-4"
                rows="5"
            ></textarea>

            <!-- LOCATION -->

            <label class="form-label">
                Location
            </label>

            <input 
                type="text" 
                name="community[location]" 
                placeholder="Enter location"
                required
                class="form-control mb-4"
            >

            <!-- IMAGE -->

            <label class="form-label">
                Upload a Picture
            </label>

            <input 
                type="file" 
                name="image" 
                required
                class="form-control mb-4"
            >

            <!-- BUTTON -->

            <button class="post-btn">
                Post Moment ✨
            </button>

        </form>

    </div>

</div>