<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

   <!-- Gradient Banner -->
   <div class="profile-banner mb-4"></div>

   <!-- Profile Section -->
   <div class="text-center">

      <!-- Profile Image -->
      <img
         src="<%= user.profileImage?.url || 'https://images.unsplash.com/photo-1494790108377-be9c29b29330' %>"
         class="rounded-circle shadow"
         style="height:150px; width:150px; object-fit:cover;"
      >

      <!-- Username + Badge -->
      <h2 class="mt-3">

         <%= user.username %>

         <% if(avgRating >= 4){ %>

            <span class="badge bg-success">
               Super Host
            </span>

         <% } else if(listings.length >= 3){ %>

            <span class="badge bg-primary">
               Verified Host
            </span>

         <% } else { %>

            <span class="badge bg-secondary">
               New Host
            </span>

         <% } %>

      </h2>

      <!-- Email -->
      <p>
         <%= user.email %>
      </p>

      <!-- Joined Date -->
      <p class="text-muted">

         <% if(user.createdAt){ %>

   Joined
   <%= user.createdAt.toLocaleDateString("en-US", {
      month: "long",
      year: "numeric"
   }) %>

<% } else { %>

   Joined Recently

<% } %>

      </p>

      <!-- Bio -->
      <p>
         <%= user.bio || "Traveller and Explorer" %>
      </p>

      <!-- Extra Text -->
      <p class="text-secondary">
         Explorer • Host • WanderLoft Member
      </p>

      <!-- Edit Profile Button -->
      <% if(currUser && currUser._id.equals(user._id)){ %>

         <a
            href="/profile/<%= user._id %>/edit"
            class="btn btn-outline-dark mt-2"
         >
            Edit Profile
         </a>

      <% } %>

      <!-- Stats Cards -->
      <div class="row text-center mt-4">

         <!-- Total Listings -->
         <div class="col-md-4 mb-3">

            <div class="card shadow-sm p-3 profile-stat-card">

               <h3>
                  <%= listings.length %>
               </h3>

               <p>
                  Total Listings
               </p>

            </div>

         </div>

         <!-- Average Rating -->
         <div class="col-md-4 mb-3">

            <div class="card shadow-sm p-3 profile-stat-card">

               <h3>
                  <%= Number(avgRating || 0).toFixed(1) %> ⭐
               </h3>

               <p>
                  Host Rating
               </p>

            </div>

         </div>

         <!-- Hosting Status -->
         <div class="col-md-4 mb-3">

            <div class="card shadow-sm p-3 profile-stat-card">

               <h3>

                  <%= listings.length > 0 ? "Yes" : "No" %>

               </h3>

               <p>
                  Has Listings?
               </p>

            </div>

         </div>

      </div>

   </div>

   <hr>

   <!-- FAVORITE LISTINGS -->
   <h3 class="mb-4">
   Favorite Listings
</h3>

<div class="row">

<% if(user.favorites && user.favorites.length > 0){ %>

   <% for(let fav of user.favorites){ %>

      <div class="col-md-4 mb-4">

         <a
            href="/listings/<%= fav._id %>"
            style="text-decoration:none;"
         >

            <div class="card shadow-sm">

               <img
                  src="<%= fav.image?.url || 'https://images.unsplash.com/photo-1494790108377-be9c29b29330' %>"
                  class="card-img-top"
                  style="height:200px; object-fit:cover;"
               >

               <div class="card-body">

                  <h5>
                     <%= fav.title %>
                  </h5>

                  <p>
                     ₹ <%= fav.price ? fav.price.toLocaleString("en-IN") : "N/A" %>
                  </p>

               </div>

            </div>

         </a>

      </div>

   <% } %>

<% } else { %>

   <p class="text-muted">
      No favorite listings yet.
   </p>

<% } %>

</div>

   <hr>

   <!-- MY LISTINGS -->
   <h3 class="mb-4">
      My Listings
   </h3>

   <% if(listings.length > 0){ %>

      <div class="row">

         <% for(let listing of listings){ %>

            <div class="col-md-4 mb-4">

               <a
                  href="/listings/<%= listing._id %>"
                  style="text-decoration:none;"
               >

                  <div class="card shadow-sm h-100">

                     <img
                        src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1494790108377-be9c29b29330' %>"
                        class="card-img-top"
                        style="height:200px; object-fit:cover;"
                     >

                     <div class="card-body">

                        <h5>
                           <%= listing.title %>
                        </h5>

                        <p>
                           ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %>
                        </p>

                        <p class="text-muted">
                           <%= listing.location %>
                        </p>

                     </div>

                  </div>

               </a>

            </div>

         <% } %>

      </div>

   <% } else { %>

      <p class="text-muted">
         No listings posted yet.
      </p>

   <% } %>

</div>